[Table("producto")]
public class Producto
{
    [Key]
    [Column("codigo")]
    [StringLength(30)]
    public string Codigo { get; set; }

    [Required]
    [Column("nombre")]
    [StringLength(100)]
    public string Nombre { get; set; }

    [Column("stock")]
    public int Stock { get; set; }

    [Column("valorunitario", TypeName = "numeric(14,2)")]
    public decimal ValorUnitario { get; set; }

    public ICollection<ProductoPorFactura> ProductosPorFactura { get; set; }
}