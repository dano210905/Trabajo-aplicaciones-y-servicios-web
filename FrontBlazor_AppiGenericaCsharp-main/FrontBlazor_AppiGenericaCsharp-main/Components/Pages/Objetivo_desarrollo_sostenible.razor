@page "/objetivo_desarrollo_sostenible"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>objetivo_desarrollo_sostenible</PageTitle>

<div class="container mt-4">

    <h3>objetivo_desarrollo_sostenible</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Registro</button>
    }

    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Registro" : "Nuevo Registro")
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label>id</label>
                        <input class="form-control" type="number" @bind="campo_id" disabled="@editando" />
                    </div>

                    <div class="col-md-5 mb-3">
                        <label>nombre</label>
                        <input class="form-control" @bind="campo_nombre" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>categoria</label>
                        <input class="form-control" @bind="campo_categoria" />
                    </div>

                </div>

                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>id</th>
                    <th>nombre</th>
                    <th>categoria</th>
                    <th>acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["nombre"]</td>
                        <td>@reg["categoria"]</td>

                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }

</div>

@code {

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;

    private string mensaje = "";
    private bool exito = false;

    private int? limite = null;

    private int campo_id;
    private string campo_nombre = "";
    private string campo_categoria = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("objetivo_desarrollo_sostenible", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;

        campo_id = 0;
        campo_nombre = "";
        campo_categoria = "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;

        campo_id = Convert.ToInt32(reg["id"]);
        campo_nombre = reg["nombre"]?.ToString() ?? "";
        campo_categoria = reg["categoria"]?.ToString() ?? "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campo_id,
            ["nombre"] = campo_nombre,
            ["categoria"] = campo_categoria
        };

        if (editando)
        {
            datos.Remove("id");

            var resultado = await Api.ActualizarAsync("objetivo_desarrollo_sostenible", "id", campo_id, datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("objetivo_desarrollo_sostenible", datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int id = Convert.ToInt32(reg["id"]);

        var resultado = await Api.EliminarAsync("objetivo_desarrollo_sostenible", "id", id);

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = "";
    }

}