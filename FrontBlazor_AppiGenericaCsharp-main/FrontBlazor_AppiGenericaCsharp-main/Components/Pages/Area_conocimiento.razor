```razor
@page "/area_conocimiento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Areas_de_Conocimiento</PageTitle>

<div class="container mt-4">
    <h3>Areas_de_Conocimiento</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva_Área</button>
    }

    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Área de Conocimiento" : "Nueva Área de Conocimiento")
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-3 mb-3">
                        <label>ID</label>
                        <input class="form-control" type="number" @bind="campoId" disabled="@editando" />
                    </div>

                    <div class="col-md-9 mb-3">
                        <label>Gran Área</label>
                        <input class="form-control" @bind="campoGranArea" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Área</label>
                        <input class="form-control" @bind="campoArea" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Disciplina</label>
                        <input class="form-control" @bind="campoDisciplina" />
                    </div>

                </div>

                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>

            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Gran Área</th>
                    <th>Área</th>
                    <th>Disciplina</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["gran_area"]</td>
                        <td>@reg["area"]</td>
                        <td>@reg["disciplina"]</td>

                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }

</div>

@code {

    private List<Dictionary<string, object?>> registros = new();

    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;

    private string mensaje = "";
    private bool exito = false;

    private int? limite = null;

    private int campoId;
    private string campoGranArea = "";
    private string campoArea = "";
    private string campoDisciplina = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("area_conocimiento", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;

        campoId = 0;
        campoGranArea = "";
        campoArea = "";
        campoDisciplina = "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;

        campoId = Convert.ToInt32(reg["id"]);
        campoGranArea = reg["gran_area"]?.ToString() ?? "";
        campoArea = reg["area"]?.ToString() ?? "";
        campoDisciplina = reg["disciplina"]?.ToString() ?? "";

        mostrarFormulario = true;
        mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["gran_area"] = campoGranArea,
            ["area"] = campoArea,
            ["disciplina"] = campoDisciplina
        };

        if (editando)
        {
            datos.Remove("id");

            var resultado = await Api.ActualizarAsync("area_conocimiento", "id", campoId, datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("area_conocimiento", datos);

            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        int id = Convert.ToInt32(reg["id"]);

        var resultado = await Api.EliminarAsync("area_conocimiento", "id", id);

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = "";
    }

}
```
